# ===== 钉钉配置（敏感信息）=====
# 钉钉开发者应用 AppKey
DINGTALK_APP_KEY=dingxxxxxxxxxxxx
# 钉钉开发者应用 AppSecret
DINGTALK_APP_SECRET=your_app_secret_here
# 操作人 unionId（全局一个，所有表格共用）
DINGTALK_OPERATOR_ID=your_operator_unionid

# ===== 服务配置（敏感信息）=====
# API 鉴权 Key，钉钉自动化回调时携带 Authorization: Bearer <API_KEY>
API_KEY=your-secret-api-key-change-me

# ===== AI 生图配置（敏感信息）=====
# 每个表格在 config.toml 中通过 gpt_image_api_key_env / nanobanana_api_key_env
# 指定使用哪个环境变量。可自由扩展，只需保持命名一致。

# 卓智
ZHUOZHI_NANOBANANA_API_KEY=your-zhuozhi-nanobanana-key
ZHUOZHI_GPT_IMAGE_API_KEY=your-zhuozhi-gpt-image-key

# AHMI
AHMI_NANOBANANA_API_KEY=your-ahmi-nanobanana-key
AHMI_GPT_IMAGE_API_KEY=your-ahmi-gpt-image-key

# 华普
HUAPU_NANOBANANA_API_KEY=your-huapu-nanobanana-key
HUAPU_GPT_IMAGE_API_KEY=your-huapu-gpt-image-key

# configs/.env 环境变量模板
# 复制此文件为 configs/.env 并填入真实值

# ===== 钉钉配置 =====
# 钉钉开发者应用 AppKey
DINGTALK_APP_KEY=dingxxxxxxxxxxxx
# 钉钉开发者应用 AppSecret
DINGTALK_APP_SECRET=your_app_secret_here
# 默认多维表格 ID（URL 中可获取）
DINGTALK_TABLE_ID=tbl_xxxxxxxx
# 云空间 ID（用于上传生成图片）
DINGTALK_SPACE_ID=spc_xxxxxxxx

# ===== 服务配置 =====
# API 鉴权 Key，钉钉自动化请求时携带
API_KEY=your-secret-api-key-change-me
# 监听地址
HOST=0.0.0.0
# 监听端口
PORT=8000
# 日志级别: DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# ===== AI 生图配置 =====
# 默认生图模型（根据表格"生图模型"字段可选值预设）
DEFAULT_MODEL=flux-1.1-pro

# OpenAI API Key（DALL-E 3 等）
OPENAI_API_KEY=sk-xxxxxxxx

# Stability AI API Key（SDXL 等）
STABILITY_API_KEY=sk-xxxxxxxx

# Replicate API Key（Flux 等）
REPLICATE_API_KEY=r8_xxxxxxxx
